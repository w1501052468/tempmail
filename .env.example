# ================================
# TempMail 示例配置文件
# ================================
#
# 使用方法：
# 1. 复制为 .env
#    cp .env.example .env
# 2. 运行脚本生成随机密钥
#    sh scripts/generate-secrets.sh
# 3. 按下面说明修改关键项
#
# 特别说明：
# - 下面“运行时默认值”类配置，首次启动后会作为默认配置写入系统。
# - 如果你后续在 /admin 修改了这些运行时配置，数据库中的值会覆盖这里的默认值。
# - 域名、端口、证书、Docker 挂载路径等部署级配置，仍然以 .env / docker-compose.yml 为准。


# ================================
# 一、Compose 与时区
# ================================

# Docker Compose 项目名。
# 会影响容器名、网络名、卷名前缀。
COMPOSE_PROJECT_NAME=tempmail

# 容器时区。
# 建议与你的服务器所在地或运维习惯保持一致。
TZ=Asia/Shanghai


# ================================
# 二、域名与证书
# ================================

# 你的根域名。
# 默认情况下：
# - Web / API / 管理后台域名：mail.<ROOT_DOMAIN>
# - SMTP / MX 主机名：mx.<ROOT_DOMAIN>
ROOT_DOMAIN=test.com

# Web / API / 管理后台域名。
# 这个域名可以走 Cloudflare 代理（小黄云）。
WEB_HOSTNAME=mail.test.com

# SMTP / MX 主机名。
# 这个域名必须保持“仅 DNS”，不能走 Cloudflare 普通代理。
SMTP_HOSTNAME=mx.test.com

# 兼容旧变量，通常不需要再单独设置。
# 如果你已经有旧部署，也可以继续保留它；未设置 SMTP_HOSTNAME 时会回退使用这个值。
# POSTFIX_HOSTNAME=mx.test.com

# ACME / Let's Encrypt 申请证书使用的邮箱。
ACME_EMAIL=admin@test.com

# ACME 服务商。
# 常用值：
# - letsencrypt
# - zerossl
ACME_SERVER=letsencrypt

# 证书密钥类型。
# 推荐 ec-256，兼顾性能与现代兼容性。
ACME_KEYLENGTH=ec-256


# ================================
# 三、数据库
# ================================

# PostgreSQL 数据库名。
POSTGRES_DB=tempmail

# PostgreSQL 用户名。
POSTGRES_USER=tempmail

# PostgreSQL 密码。
# 必须改成强随机值。
POSTGRES_PASSWORD=change-this-db-password

# PostgreSQL 主机名。
# Docker Compose 默认使用服务名 db。
POSTGRES_HOST=db

# PostgreSQL 端口。
POSTGRES_PORT=5432

# 备用 DSN。
# 当前代码优先读取 POSTGRES_HOST / PORT / DB / USER / PASSWORD。
# 这个值更多作为兼容保留，建议仍保持正确。
DATABASE_DSN=postgresql://tempmail:change-this-db-password@db:5432/tempmail


# ================================
# 四、可创建邮箱的基础域名
# ================================

# 允许创建邮箱的基础域名。
# 多个域名用英文逗号分隔，不要加空格。
# 例如：
# BASE_DOMAINS=test.com,test.net
#
# 每个基础域名都必须在 DNS 中配置：
# - 根域名 MX
# - 通配子域 MX
# 如果你准备完全改用后台“基础域名”管理，这里也可以留空；
# 若填写，则会在启动时作为种子域名写入数据库，并立即标记为 active。
BASE_DOMAINS=test.com

# 默认基础域名。
# 若 BASE_DOMAINS 为空，则系统会优先使用后台第一个 active 域名。
# 当创建邮箱接口未传 domain 时，会优先使用这个值。
DEFAULT_BASE_DOMAIN=test.com


# ================================
# 五、API 与代理信任
# ================================

# API 监听地址。
# 当前 Dockerfile 已固定使用 0.0.0.0。
# 保持默认即可，除非你同步修改 Dockerfile / 反向代理。
API_HOST=0.0.0.0

# API 容器内部端口。
# 当前 Dockerfile 与 Nginx 都按 8080 工作。
# 修改它时需要同步改 Dockerfile、Nginx、Compose。
API_PORT=8080

# 是否信任反向代理头。
# 当前部署使用 Nginx 反代，建议保持 true。
# 否则 API 返回的外链可能会错误地显示为 http://。
TRUST_PROXY_HEADERS=true


# ================================
# 六、Nginx / Edge 对外端口与限流
# ================================

# 宿主机 HTTP 端口。
# 用于：
# - ACME HTTP-01 验证
# - 自动跳转到 HTTPS
# 通常必须保持 80。
EDGE_HTTP_PORT=80

# 宿主机 HTTPS 端口。
# 通常保持 443。
EDGE_HTTPS_PORT=443

# 全局接口限流速率。
# 示例：30r/s 表示每秒 30 次。
EDGE_GENERAL_RATE=30r/s

# 全局接口突发桶大小。
EDGE_GENERAL_BURST=60

# 创建邮箱接口限流速率。
# 默认比普通接口更严格。
EDGE_CREATE_RATE=10r/m

# 创建邮箱接口突发桶大小。
EDGE_CREATE_BURST=20

# inbox 读取接口限流速率。
EDGE_INBOX_RATE=120r/m

# inbox 读取接口突发桶大小。
EDGE_INBOX_BURST=60


# ================================
# 七、Token 与管理员安全配置
# ================================

# 邮箱访问 token 的哈希密钥。
# 必须为长随机串。
# 绝对不要使用示例值直接上线。
APP_TOKEN_HASH_SECRET=change-this-very-long-random-secret

# 管理后台用户名。
ADMIN_USERNAME=admin

# 管理后台密码。
# 必须修改为强密码。
ADMIN_PASSWORD=change-this-admin-password

# 管理后台会话签名密钥。
# 必须为长随机串。
ADMIN_SESSION_SECRET=change-this-admin-session-secret

# 管理后台登录会话有效期（小时）。
ADMIN_SESSION_HOURS=12

# 返回给客户端的 token 前缀。
# 默认 tm_，一般不需要改。
TOKEN_PREFIX=tm_

# token 随机字节数。
# 越大越长，安全性越高。
TOKEN_BYTES=32


# ================================
# 八、邮箱生成规则（运行时默认值）
# 这些值可在 /admin 中热更新
# ================================

# 默认邮箱有效期（分钟）。
MAILBOX_DEFAULT_TTL_MINUTES=60

# 允许创建的最小 TTL（分钟）。
MAILBOX_MIN_TTL_MINUTES=10

# 允许创建的最大 TTL（分钟）。
MAILBOX_MAX_TTL_MINUTES=1440

# 兼容旧配置：邮箱本地部分固定长度。
# 若同时设置下面的 MIN/MAX，则优先使用范围配置。
MAILBOX_LOCAL_PART_LENGTH=10

# 兼容旧配置：随机子域固定长度。
# 若同时设置下面的 MIN/MAX，则优先使用范围配置。
MAILBOX_SUBDOMAIN_LENGTH=8

# 邮箱本地部分随机长度范围。
MAILBOX_LOCAL_PART_MIN_LENGTH=6
MAILBOX_LOCAL_PART_MAX_LENGTH=10

# 随机子域长度范围。
MAILBOX_SUBDOMAIN_MIN_LENGTH=4
MAILBOX_SUBDOMAIN_MAX_LENGTH=8


# ================================
# 九、API 业务限流（运行时默认值）
# 这些值可在 /admin 中热更新
# ================================

# 单 IP 创建邮箱次数限制。
CREATE_RATE_LIMIT_COUNT=30

# 创建邮箱限流时间窗（秒）。
CREATE_RATE_LIMIT_WINDOW_SECONDS=3600

# 单 token 收件箱读取次数限制。
INBOX_RATE_LIMIT_COUNT=600

# 收件箱读取限流时间窗（秒）。
INBOX_RATE_LIMIT_WINDOW_SECONDS=600


# ================================
# 十、邮件解析与保留策略（运行时默认值）
# 这些值可在 /admin 中热更新
# ================================

# 单封邮件最大字节数。
# 注意：
# - API / ingest 层会读取这个值
# - Postfix SMTP 层也会在容器启动时使用这个值生成配置
# 如果你在线修改了它，建议同时更新 .env 并重建 postfix，
# 避免“应用层上限”和“SMTP 层上限”不一致。
MESSAGE_SIZE_LIMIT_BYTES=10485760

# 保存的纯文本正文最大字符数。
MAX_TEXT_BODY_CHARS=200000

# 保存的 HTML 正文最大字符数。
MAX_HTML_BODY_CHARS=200000

# 单封邮件最多保留多少个附件。
MAX_ATTACHMENTS_PER_MESSAGE=20


# ================================
# 十一、清理策略（运行时默认值）
# 这些值可在 /admin 中热更新
# ================================

# 邮箱过期或禁用后，经过多少分钟才开始物理删除数据。
PURGE_GRACE_MINUTES=60

# 访问事件日志保留天数。
ACCESS_EVENT_RETENTION_DAYS=7

# 单次清理最多处理多少个邮箱。
CLEANUP_BATCH_SIZE=200

# janitor 清理轮询间隔（秒）。
# 这是容器命令层参数，不属于 /admin 热更新范围。
JANITOR_INTERVAL_SECONDS=300

# 域名监控器轮询间隔（秒）。
DOMAIN_MONITOR_LOOP_SECONDS=30

# 待验证 / 已启用 / 已停用基础域名的自动检查间隔（秒）。
DOMAIN_VERIFY_PENDING_INTERVAL_SECONDS=30
DOMAIN_VERIFY_ACTIVE_INTERVAL_SECONDS=21600
DOMAIN_VERIFY_DISABLED_INTERVAL_SECONDS=1800

# active 域名连续失败多少次后自动禁用。
DOMAIN_VERIFY_FAILURE_THRESHOLD=2

# 单次 DNS 查询超时（秒）。
DOMAIN_DNS_TIMEOUT_SECONDS=5

# 可选：为基础域名 MX 校验指定 DNS 解析器。
# 逗号分隔，例如：
# DOMAIN_DNS_RESOLVERS=1.1.1.1,8.8.8.8
DOMAIN_DNS_RESOLVERS=


# ================================
# 十二、数据目录
# ================================

# 容器内数据目录。
# 当前 docker-compose.yml 会把宿主机 ./runtime/data 挂载到容器内 /data。
# 使用当前编排时，建议不要改这个值。
DATA_DIR=/data


# ================================
# 十三、Postfix 连接级限制
# 这些值属于部署级配置，需要重建 postfix 生效
# ================================

# 单客户端连接速率限制。
POSTFIX_CLIENT_CONNECTION_RATE_LIMIT=30

# 单客户端消息速率限制。
POSTFIX_CLIENT_MESSAGE_RATE_LIMIT=60

# 单客户端收件人速率限制。
POSTFIX_CLIENT_RECIPIENT_RATE_LIMIT=120
